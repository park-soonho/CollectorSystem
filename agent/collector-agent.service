[Unit]
Description=CollectorSystem – Agent Server
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/CollectorSystem/agent
EnvironmentFile=/opt/CollectorSystem/agent/.env
ExecStart=/usr/bin/python3 /opt/CollectorSystem/agent/agent_server.py
Restart=always
RestartSec=10
StandardOutput=append:/var/log/collector/agent.log
StandardError=append:/var/log/collector/agent.error.log

[Install]
WantedBy=multi-user.target
